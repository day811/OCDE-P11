{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [

        {
            "name": "Fetch data",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/vector/run_pipeline.py",
            "console": "integratedTerminal",
            "args": [
                "--max-pages",
                "100",

            ],
        },
        {
            "name": "Vectorize data",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/vector/run_full_pipeline.py",
            "console": "integratedTerminal",
            "args": [
                "--vectorize-only",
                "--snapshot-date",
                "2026-02-05"
            ],
        },
        {
            "name": "Search CLI",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/cli.py",
            "console": "integratedTerminal",
            "args": [
                "search",
                "--question",
                "Je cherche des evenements sur l'emploi la semaine prochaine",
                "--date",
                "2026-02-03"
            ],
        },
        {
            "name": "Streamlit Debug",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": ["run", "main.py"],
            "jinja": true,
            "justMyCode": true,
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}"
        }

    ]
}