    "version": "0.2.0",
    "configurations": [

        {
            "name": "Fetch data",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_full_pipeline.py",
            "console": "integratedTerminal",
            "args": [
                "--max-pages",
                "100"
            ],
        },
        {
            "name": "Search CLI",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "args": [
                "search",
                "--question",
                "Je cherche des des choses à faire ce week-end dans l'Hérault",
                "--date",
                "2026-01-31"
            ],
        },
        {
            "name": "Chat CLI",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "args": [
                "chat",
                "--date",
                "2026-01-31"
            ],
        },
       {
            "name": "Chat UI",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/main.py",
            "console": "integratedTerminal",
            "args": [
                "api"
            ],
        },

    ]
}