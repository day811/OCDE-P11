# RAG System Configuration
# Copy this file to .env and customize values

# ============= ENVIRONMENT =============
# Options: development, demo, production
RAG_ENVIRONMENT=development

# ============= DATA PARAMETERS =============
# Geographic region for event filtering
RAG_REGION=YouRegio

# FROZEN snapshot for reproducible testing (Phase 2-5)
DEV_SNAPSHOT_DATE = "2026-01-29"

# Historical period (days) for data collection
RAG_DAYS_BACK=365
## Number of pages to fetch
MAX_PAGES=100

# ============ LLM PROVIDER ============
# Options: mistral, openai, gemini
LLM_PROVIDER=mistral

# API Keys (provide the one for your selected provider)
LLM_API_KEY=
# Or provider-specific:
MISTRAL_API_KEY=...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ============ MODEL SELECTION ============
# Leave empty to use provider defaults

# Mistral models
MISTRAL_CHAT_MODEL=mistral-small
MISTRAL_EMBED_MODEL=mistral-embed

# OpenAI models
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Gemini models
GEMINI_CHAT_MODEL=gemini-1.5-flash
GEMINI_EMBED_MODEL=models/embedding-001

# ============ GENERATION PARAMETERS ============
# Temperature: 0.0 (deterministic) to 1.0 (random)
LLM_TEMPERATURE=0.7
